-- =========================
-- HELPERS
-- =========================
local function getChar()
    local chr = plr.Character or plr.CharacterAdded:Wait()
    return chr, chr:WaitForChild("HumanoidRootPart")
end

local function hasJoinedTeam()
    return plr.Team ~= nil and plr.Team.Name ~= "Players"
end

-- Check đã mua Sharkman Karate chưa (chuẩn nhất)
local function hasSharkmanKarate()
    local data = plr:FindFirstChild("Data")
    if data and data:FindFirstChild("FightingStyle") and data.FightingStyle.Value then
        return tostring(data.FightingStyle.Value) == "Sharkman Karate"
    end

    -- Fallback (phòng khi game đổi cấu trúc)
    local chr = plr.Character
    if chr then
        for _, v in ipairs(chr:GetChildren()) do
            if v:IsA("Tool") and v.Name:lower():find("sharkman") then
                return true
            end
        end
    end
    for _, v in ipairs(plr.Backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find("sharkman") then
            return true
        end
    end
    return false
end

-- Tween tới vị trí (xuyên tường + bay cao)
local function tweenTo(pos)
    local _, hrp = getChar()

    -- giữ đứng thẳng (giảm rung)
    task.spawn(function()
        while (hrp.Position - pos).Magnitude > 5 do
            hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + Vector3.new(0, 0, -1))
            task.wait()
        end
    end)

    local safeHeight = 150
    if pos.Y < safeHeight then
        pos = Vector3.new(pos.X, safeHeight, pos.Z)
    end

    local speed = 320
    local distance = (hrp.Position - pos).Magnitude
    local time = distance / speed

    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        { CFrame = CFrame.new(pos) }
    )
    tween:Play()
    tween.Completed:Wait()
end

local function buySharkmanKarate()
    -- Remote mua
    local ok, res = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("BuySharkmanKarate")
    end)
    return ok, res
end

